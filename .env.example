# Shopping Mini App - Environment Variables
# Copy this file to .env and fill in your values

# Ruta al archivo de la lista de la compra
# Por defecto apunta a /data/shared/SHOPPING.md (el archivo real está en el workspace compartido de OpenClaw)
SHOPPING_FILE_PATH=/data/shared/SHOPPING.md

# ID de usuario de Telegram permitido para modificar la lista
# Obtén tu ID hablando con @userinfobot en Telegram
ALLOWED_USER_ID=123456789

# Ruta al archivo de notificaciones para Sancho (OpenClaw)
# Debe ser accesible desde el workspace de OpenClaw
NOTIFICATION_FILE_PATH=/root/.openclaw/workspace/.shopping-changes.json
